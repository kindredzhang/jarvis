#!/usr/bin/env bun
/**
 * jarvis CLI entry point for global `npm install -g` installation.
 *
 * This file is the "bin" target in package.json. When installed globally
 * via `npm install -g`, the `jarvis` command invokes this script, which
 * delegates to the TypeScript CLI entry point.
 */

import { join, dirname } from 'node:path'
import { fileURLToPath } from 'node:url'

const __dirname = dirname(fileURLToPath(import.meta.url))
process.argv.splice(1, 1, join(__dirname, '..', 'src', 'cli.ts'))
await import(join(__dirname, '..', 'src', 'cli.ts'))
