#!/bin/bash
# jarvis launcher — starts Bun API server + Python TUI
# Usage: ./bin/jarvis [agent|gateway|serve|onboard|status] [options]

set -e

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
PID_FILE="$ROOT/.jarvis-server.pid"
API_PORT="${JARVIS_PORT:-8000}"

# Colors
GREEN='\033[0;32m'
DIM='\033[0;2m'
RED='\033[0;31m'
NC='\033[0m'

# ──── Helpers ────

is_server_running() {
    curl -s "http://localhost:$API_PORT/health" > /dev/null 2>&1
}

start_server() {
    if is_server_running; then
        echo -e "${DIM}Server already running on :$API_PORT${NC}"
        return 0
    fi
    echo -e "${DIM}Starting jarvis server on :$API_PORT...${NC}"
    cd "$ROOT"
    bun run jarvis serve -p "$API_PORT" &
    SERVER_PID=$!
    echo "$SERVER_PID" > "$PID_FILE"

    # Wait for server to be ready
    for i in {1..30}; do
        if is_server_running; then
            echo -e "${GREEN}✓${NC} Server ready"
            return 0
        fi
        sleep 0.2
    done
    echo -e "${RED}✗ Server failed to start${NC}"
    return 1
}

stop_server() {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE" 2>/dev/null)
        if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
            kill "$PID" 2>/dev/null
            rm -f "$PID_FILE"
            echo -e "${DIM}Server stopped${NC}"
        fi
    fi
}

# ──── Main ────

case "${1:-agent}" in
    agent|gateway|onboard|status)
        CMD="$1"
        shift
        start_server
        trap 'stop_server' EXIT
        cd "$ROOT/tui"
        exec uv run jarvis "$CMD" "$@"
        ;;
    serve)
        shift
        cd "$ROOT"
        exec bun run jarvis serve "$@"
        ;;
    test)
        shift
        cd "$ROOT"
        exec bun test "$@"
        ;;
    install)
        echo -e "${GREEN}Installing jarvis...${NC}"
        cd "$ROOT"
        echo -e "${DIM}  → bun dependencies${NC}"
        bun install --silent
        cd "$ROOT/tui"
        echo -e "${DIM}  → python dependencies${NC}"
        uv sync --quiet
        echo -e "${GREEN}✓ jarvis installed${NC}"
        echo -e "${DIM}  Usage: ./bin/jarvis agent${NC}"
        ;;
    clean)
        rm -f "$ROOT/.jarvis-server.pid"
        echo -e "${DIM}Cleaned${NC}"
        ;;
    *)
        echo "Usage: jarvis [agent|gateway|serve|onboard|status|install|clean|test]"
        exit 1
        ;;
esac
