{
    "name": "@kindred/jarvis",
    "version": "1.0.0",
    "description": "Personal AI Assistant — ReAct agent with tool use, multi-provider LLM support, session persistence, memory consolidation, and chat channel integrations",
    "type": "module",
    "bin": {
        "jarvis": "bin/jarvis"
    },
    "files": [
        "bin/",
        "src/",
        "templates/",
        "skills/",
        "types/",
        "tsconfig.json",
        "README.md"
    ],
    "engines": {
        "bun": ">=1.0.0"
    },
    "scripts": {
        "start": "jarvis agent",
        "test": "bun test",
        "prepublishOnly": "bun test",
        "postinstall": "echo 'jarvis installed! Run `jarvis --help` to get started.'"
    },
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/kindredzhang/jarvis.git"
    },
    "keywords": [
        "ai",
        "agent",
        "llm",
        "cli",
        "assistant",
        "react",
        "mcp",
        "bun"
    ],
    "license": "MIT",
    "devDependencies": {
        "@types/bun": "latest",
        "typescript": "^5"
    },
    "dependencies": {
        "@clack/prompts": "^1.3.0",
        "@larksuiteoapi/node-sdk": "^1.63.1",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@types/cli-spinners": "^2.0.0",
        "chalk": "5",
        "cli-spinners": "^3.4.0",
        "commander": "^14.0.3",
        "marked": "^18.0.3",
        "marked-terminal": "^7.3.0"
    }
}